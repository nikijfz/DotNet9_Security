@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success text-start" dir="ltr">@TempData["Message"]</div>
}

<div dir="ltr" class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0">Roles List</h2>
        <a asp-controller="Role" asp-action="RegisterRole" class="btn btn-primary">Create New Role</a>
    </div>

    <table class="table table-bordered table-striped text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Role Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    <td>@role.Name</td>
                    <td>
                        <form asp-action="Delete" asp-controller="Role" method="post" onsubmit="return confirm('Are you sure you want to delete this role?');">
                            <input type="hidden" name="roleId" value="@role.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>