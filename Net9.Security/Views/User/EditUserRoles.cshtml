@model Net9.Security.Controllers.Dtos.EditUserRolesDto

<div dir="ltr" class="container mt-4" style="max-width: 500px;">
    <h2>Manage Roles for [@Model.UserName]</h2>
    <hr />

    <form asp-action="EditUserRoles" method="post">
        <input type="hidden" name="userId" value="@Model.UserId" />

        <div class="card mb-3">
            <div class="card-header bg-dark text-white">
                Available System Roles
            </div>
            <div class="card-body">
                @foreach (var role in Model.Roles)
                {
                    bool isSelected = Model.UserRoles.Contains(role.Name);

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="roles" value="@role.Name" @(isSelected ? "checked" : "") />
                        <label class="form-check-label">
                            @role.Name
                        </label>
                    </div>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-success w-100">Update Roles</button>
        <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Back to List</a>
    </form>
</div>